<?xml version="1.0"?>
<robot name="my_robot">

  <link name="base_link">
    <visual>
      <geometry><box size="0.9 0.6 0.3"/></geometry>
      <material name="yellow"><color rgba="1 0.8 0 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.9 0.6 0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.1125" ixy="0.0" ixz="0.0" iyy="0.225" iyz="0.0" izz="0.2925"/>
    </inertial>
  </link>

  <link name="left_wheel">
    <visual>
      <geometry><cylinder radius="0.15" length="0.12"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.15" length="0.12"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.002048" ixy="0.0" ixz="0.0" iyy="0.002048" iyz="0.0" izz="0.003375"/>
    </inertial>
  </link>

  <link name="right_wheel">
    <visual>
      <geometry><cylinder radius="0.15" length="0.12"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.15" length="0.12"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.002048" ixy="0.0" ixz="0.0" iyy="0.002048" iyz="0.0" izz="0.003375"/>
    </inertial>
  </link>

  <link name="front_caster">
    <visual>
      <geometry><sphere radius="0.06"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.06"/></geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.000216" ixy="0.0" ixz="0.0" iyy="0.000216" iyz="0.0" izz="0.000216"/>
    </inertial>
  </link>

  <link name="back_caster">
    <visual>
      <geometry><sphere radius="0.06"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.06"/></geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.000216" ixy="0.0" ixz="0.0" iyy="0.000216" iyz="0.0" izz="0.000216"/>
    </inertial>
  </link>

  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.09" length="0.12"/></geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.09" length="0.12"/></geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.000484" ixy="0.0" ixz="0.0" iyy="0.000484" iyz="0.0" izz="0.000608"/>
    </inertial>
  </link>

  <link name="left_fork">
    <visual>
      <geometry><box size="1.05 0.12 0.06"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><box size="1.05 0.12 0.06"/></geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.000225" ixy="0.0" ixz="0.0" iyy="0.013826" iyz="0.0" izz="0.013961"/>
    </inertial>
  </link>

  <link name="right_fork">
    <visual>
      <geometry><box size="1.05 0.12 0.06"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><box size="1.05 0.12 0.06"/></geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.000225" ixy="0.0" ixz="0.0" iyy="0.013826" iyz="0.0" izz="0.013961"/>
    </inertial>
  </link>

  <link name="mast">
    <visual>
      <geometry><box size="0.15 0.54 1.05"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.15 0.54 1.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.034853" ixy="0.0" ixz="0.0" iyy="0.028125" iyz="0.0" izz="0.007853"/>
    </inertial>
  </link>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.09 0.09 0.09"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.09 0.09 0.09"/></geometry>
    </collision>
    <inertial>
      <mass value="0.06"/>
      <inertia ixx="0.000081" ixy="0.0" ixz="0.0" iyy="0.000081" iyz="0.0" izz="0.000081"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.0 0.36 -0.075" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.0 -0.36 -0.075" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster"/>
    <origin xyz="0.36 0.0 -0.2" rpy="0 0 0"/>
  </joint>

  <joint name="back_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="back_caster"/>
    <origin xyz="-0.36 0.0 -0.2" rpy="0 0 0"/>
  </joint>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.0 0.0 1.35" rpy="0 0 0"/>
  </joint>

  <joint name="left_fork_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_fork"/>
    <origin xyz="0.975 0.18 -0.18" rpy="0 0 0"/>
  </joint>

  <joint name="right_fork_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_fork"/>
    <origin xyz="0.975 -0.18 -0.18" rpy="0 0 0"/>
  </joint>

  <joint name="mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="mast"/>
    <origin xyz="0.48 0.0 0.675" rpy="0 0 0"/>
  </joint>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.57 0.0 1.2" rpy="0 0 0"/>
  </joint>

  <gazebo reference="base_link"><material>Gazebo/Yellow</material></gazebo>
  <gazebo reference="left_wheel"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="right_wheel"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="left_fork"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="right_fork"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="mast"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="camera_link"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="front_caster">
    <material>Gazebo/Grey</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>
  <gazebo reference="back_caster">
    <material>Gazebo/Grey</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>
  <gazebo reference="lidar_link">
    <material>Gazebo/Red</material>
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>10.0</max>
          <resolution>0.015</resolution>
        </range>
      </ray>
      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor type="camera" name="camera">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.396</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>15</far>
        </clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <camera_name>forklift_camera</camera_name>
        <frame_name>camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.72</wheel_separation>
      <wheel_diameter>0.3</wheel_diameter>
      <max_wheel_torque>60</max_wheel_torque>
      <max_wheel_acceleration>1.5</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

</robot>
